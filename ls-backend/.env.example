# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/ls_marketplace?schema=public"

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─── 2FA / OTP ────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ─── EMAIL (SendGrid ou SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@ls-marketplace.com
EMAIL_FROM_NAME=LS Marketplace

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── PAIEMENT STRIPE ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ─── PAIEMENT FEDAPAY (Mobile Money Afrique) ──────────────────────────────────
FEDAPAY_SECRET_KEY=sk_sandbox_your_fedapay_secret
FEDAPAY_PUBLIC_KEY=pk_sandbox_your_fedapay_public
FEDAPAY_WEBHOOK_SECRET=your_fedapay_webhook_secret
FEDAPAY_ENV=sandbox

# ─── STOCKAGE FICHIERS (Cloudflare R2 / AWS S3) ───────────────────────────────
S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key
S3_SECRET_ACCESS_KEY=your_r2_secret_key
S3_BUCKET_NAME=ls-marketplace
S3_REGION=auto
CDN_URL=https://cdn.ls-marketplace.com

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── ESCROW ───────────────────────────────────────────────────────────────────
ESCROW_RELEASE_DELAY_HOURS=48
COMMISSION_RATE=0.03

# ─── CHIFFREMENT (AES-256-GCM pour secrets 2FA) ───────────────────────────────
# Générer avec : openssl rand -base64 32
ENCRYPTION_KEY=your_32_bytes_base64_encoded_key_here

# ─── SWAGGER (docs API) ───────────────────────────────────────────────────────
# Mettre SWAGGER_ENABLED=true en prod pour activer /api/docs (protégé basic auth)
SWAGGER_ENABLED=false
SWAGGER_USER=admin
SWAGGER_PASS=ls-docs-change-me

# ─── SITE URL (SEO sitemap) ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ls-marketplace.com
