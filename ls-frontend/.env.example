# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SITE_URL=https://ls-marketplace.com

# ─── STRIPE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── WEB PUSH (VAPID) ────────────────────────────────────────────────────────
# Doit correspondre à VAPID_PUBLIC_KEY du backend
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── SENTRY ──────────────────────────────────────────────────────────────────
# DSN public (affiché côté client)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# DSN privé (serveur Next.js uniquement)
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# Pour l'upload des source maps (CI/CD uniquement)
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=ls-frontend
